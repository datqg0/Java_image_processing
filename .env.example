# ============================================================
# Environment variables for Java Image Processing App
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is listed in .gitignore — never commit the real keys.

# remove.bg API key — https://www.remove.bg/api
REMOVE_BG_API_KEY=your_api_key_here

# Path to the folder containing opencv_javaXXXX.dll (Windows) or libopencv_javaXXXX.so (Linux/Mac)
# Example Windows: C:\opencv\build\java\x64
# Example Linux:   /usr/local/lib
OPENCV_LIB_PATH=C:\opencv\build\java\x64
